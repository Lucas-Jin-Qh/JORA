      "coverage_rate": "2.35%",
      "expected_params": "~58K",
      "notes": "Diag 低预算基线，与 block-S96-k24 对比"
    },
    {
      "name": "diag-S64-k16",
      "core": "diag",
      "S_L": 64,
      "S_R": 64,
      "k": 16,
      "coverage_rate": "1.57%",
      "expected_params": "~57K",
      "notes": "Diag 更小配置"
    },
    {
      "name": "diag-S128-k32",
      "core": "diag",
      "S_L": 128,
      "S_R": 128,
      "k": 32,
      "coverage_rate": "3.14%",
      "expected_params": "~59K",
      "notes": "Diag 更大配置"
    }
  ],
  "fixed_params": {
    "peft_type": "JORA",
    "selection": "topk_ema",
    "ema_beta": 0.95,
    "update_interval": 50,
    "magnitude": "oer_softmax",
    "oer_temperature": 2.0,
    "rotation_param": "cayley",
    "lr_theta": 0.05,
    "lr_core": 0.01,
    "inference_mode": false,
    "ddp_allow_unused_parameters": true
